# HWPX MCP — HTTP mode configuration
# Copy this to .env and fill in secrets. Never commit the real .env.

# ---------------------------------------------------------------------------
# Authentication (REQUIRED)
# ---------------------------------------------------------------------------
# Pick ONE of the two below. MCP_TOKENS takes priority if both are set.
#
# Single token — simplest. Distribute this value to members along with the URL.
#   Generate: openssl rand -hex 32
MCP_TOKEN=replace-with-output-of-openssl-rand-hex-32

# Multiple tokens (optional) — comma separated. Use this if you want per-member
# tokens for revocation tracking. Server logs a short hash of the token used.
#   MCP_TOKENS=alice_$(openssl rand -hex 24),bob_$(openssl rand -hex 24)

# ---------------------------------------------------------------------------
# Transport (optional — defaults shown)
# ---------------------------------------------------------------------------
# MCP_MODE=http
# MCP_PORT=13701
# MCP_PATH=/mcp
# MCP_MAX_BODY_MB=50

# ---------------------------------------------------------------------------
# CORS allowlist (optional)
# ---------------------------------------------------------------------------
# Comma-separated list of origins that may call the MCP endpoint.
# Default: Claude.ai + ChatGPT web. Use '*' to allow any origin (not recommended).
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com
